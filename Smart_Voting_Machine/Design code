`timescale 1ns/1ps

module smart_voting_fsm(
    input clk,
    input rst,
    input vote_req,
    input sel_valid,
    input decode_done,
    input count_done,
    input next_vote,
    output reg [2:0] state
);

    parameter RESET_ST    = 3'b000;
    parameter IDLE        = 3'b001;
    parameter CAND_SELECT = 3'b010;
    parameter DECODE      = 3'b011;
    parameter REGISTER    = 3'b100;
    parameter COUNT       = 3'b101;
    parameter DISPLAY     = 3'b110;

    reg [2:0] next_state;

    // State Register
    always @(posedge clk or posedge rst)
    begin
        if (rst)
            state <= RESET_ST;
        else
            state <= next_state;
    end

    // Next State Logic
    always @(*)
    begin
        case (state)

            RESET_ST:
                next_state = IDLE;

            IDLE:
                if (vote_req)
                    next_state = CAND_SELECT;
                else
                    next_state = IDLE;

            CAND_SELECT:
                if (sel_valid)
                    next_state = DECODE;
                else
                    next_state = CAND_SELECT;

            DECODE:
                if (decode_done)
                    next_state = REGISTER;
                else
                    next_state = DECODE;

            REGISTER:
                next_state = COUNT;

            COUNT:
                if (count_done)
                    next_state = DISPLAY;
                else
                    next_state = COUNT;

            DISPLAY:
                if (next_vote)
                    next_state = IDLE;
                else
                    next_state = DISPLAY;

            default:
                next_state = RESET_ST;

        endcase
    end

endmodule
